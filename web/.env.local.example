# Copie para .env.local. Estas são chaves publicáveis (seguras para o navegador,
# protegidas por RLS no Supabase) — não são segredo, mas o arquivo .env.local
# mesmo assim não é commitado, por convenção.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Busca semântica real do /api/chat (embeddings via Voyage AI voyage-finance-2):
VOYAGE_API_KEY=

# Geração de resposta em linguagem natural (Claude) — AINDA NÃO IMPLEMENTADA.
# Chave de console.anthropic.com (independente da sua conta claude.ai/Claude Pro).
ANTHROPIC_API_KEY=
