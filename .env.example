# Copie para .env e preencha com valores reais (.env nunca é commitado).
# SUPABASE_URL: pegue em Project Settings > API do projeto "apen-inteligencia".
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# SUPABASE_SERVICE_ROLE_KEY: pegue em Project Settings > API keys > service_role.
# NUNCA cole esse valor no chat com o assistente — preencha direto neste arquivo.
SUPABASE_SERVICE_ROLE_KEY=

# VOYAGE_API_KEY: gerada em dashboard.voyageai.com > API Keys (ver guia no README.md).
# NUNCA cole esse valor no chat com o assistente — preencha direto neste arquivo.
VOYAGE_API_KEY=
